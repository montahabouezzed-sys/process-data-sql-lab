# Import DuckDB + Panda

import duckdb
import pandas as pd

# Connect to database
con = duckdb.connect("my_database.duckdb")



df = con.execute("""
    SELECT 
        v.vehicle_name,
        COUNT(*) AS num_runs
    FROM vehicles v
    JOIN test_runs tr ON v.vehicle_id = tr.vehicle_id
    GROUP BY v.vehicle_name
    ORDER BY num_runs DESC
""").df()

df

import matplotlib.pyplot as plt

df.plot(kind="bar", x="vehicle_name", y="num_runs", legend=False)
plt.title("Number of Test Runs per Vehicle")
plt.ylabel("Runs")
plt.show()

